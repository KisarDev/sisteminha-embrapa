{
  "name": "sisteminha-embrapa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test src/**/*.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:generate:docker": "docker run --rm -v \"$PWD\":/app -w /app --network host node:20-alpine sh -lc 'npx prisma generate'",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:docker": "docker run --rm -v \"$PWD\":/app -w /app --network host node:20-alpine sh -lc 'npx prisma migrate dev'",
    "prisma:migrate:reset:docker": "docker run --rm -v \"$PWD\":/app -w /app --network host node:20-alpine sh -lc 'npx prisma migrate reset --force'",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.19",
    "node-cron": "^4.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "prisma": {
