generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
}

enum LessonCategory {
  CHICKEN
  QUAIL
  FISH
  COMPOST
  WORM_FARM
  PLANTING
  GENERAL
}

enum ManualRecordType {
  CHICKEN_EGGS
  QUAIL_EGGS
  CHICKEN_FEED_CONVERSION
  QUAIL_FEED_CONVERSION
  FISH_FEED_CONVERSION
  HUMUS_AMOUNT
  COMPOST_AMOUNT
  FISH_HARVEST_AMOUNT
  SLAUGHTERED_BIRDS_AMOUNT
  PLANTING_EVENT
  HARVEST_EVENT
  SEED_AMOUNT
  OBSERVATION
  FREE_NOTE
}

enum SensorType {
  CHICKEN_TEMPERATURE
  CHICKEN_LUMINOSITY
  QUAIL_TEMPERATURE
  QUAIL_LUMINOSITY
  WORMFARM_SOIL_TEMPERATURE
  WORMFARM_SOIL_HUMIDITY
  COMPOST_TEMPERATURE
  COMPOST_HUMIDITY
  PLANTING_SOIL_HUMIDITY
  FISH_TANK_PH
  FISH_TANK_WATER_LEVEL
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertType {
  TEMPERATURE_HIGH
  TEMPERATURE_LOW
  LUMINOSITY_LOW
  PH_OUT_OF_RANGE
  WATER_LEVEL_LOW
  SOIL_DRY
  HUMIDITY_HIGH
  HUMIDITY_LOW
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         UserRole       @default(USER)
  isDeleted    Boolean        @default(false)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  manualRecords ManualRecord[]
  sensorReadings SensorReading[]
  alerts         Alert[]
  auditLogs    AuditLog[]
}

model SensorReading {
  id          String     @id @default(cuid())
  sensorType  SensorType
  value       Float
  source      String
  measuredAt  DateTime
  createdAt   DateTime   @default(now())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  alerts      Alert[]
}

model Alert {
  id              String         @id @default(cuid())
  type            AlertType
  severity        AlertSeverity
  sensorType      SensorType
  message         String
  value           Float
  threshold       Float
  isResolved      Boolean        @default(false)
  resolvedAt      DateTime?
  sensorReadingId String?
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  createdAt       DateTime       @default(now())
  sensorReading   SensorReading? @relation(fields: [sensorReadingId], references: [id])

  @@index([isResolved])
  @@index([sensorType])
  @@index([createdAt])
  @@index([userId])
}

model ManualRecord {
  id          String           @id @default(cuid())
  type        ManualRecordType
  quantity    Float?
  notes       String?
  observedAt  DateTime
  userId      String
  isDeleted   Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id])
}

model Lesson {
  id           String         @id @default(cuid())
  title        String
  description  String
  videoUrl     String
  category     LessonCategory @default(GENERAL)
  thumbnailUrl String?
  slug         String         @unique
  content      String
  isDeleted    Boolean        @default(false)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model DocumentationPage {
  id          String   @id @default(cuid())
  title       String
  description String
  slug        String   @unique
  content     String
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String
  payload    Json?
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}
